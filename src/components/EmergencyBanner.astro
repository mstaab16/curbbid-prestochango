---
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<div class="fixed bottom-0 inset-x-0 z-30 lg:hidden">
  <div class="bg-primary text-white border-t border-cta/60 shadow-[0_-4px_16px_rgba(0,0,0,0.18)] pb-[env(safe-area-inset-bottom)]">
    <div class="flex items-stretch h-[3.25rem]">
      <a
        href={telHref}
        class="flex-1 inline-flex items-center justify-center gap-2 text-white font-bold text-sm no-underline active:bg-white/5 transition-colors"
        aria-label={`Call ${business.phone}`}
      >
        <svg class="w-[1.125rem] h-[1.125rem]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="tabular-nums">{business.phone}</span>
      </a>
      <a
        href="/contact"
        class="flex-1 inline-flex items-center justify-center bg-cta text-primary font-bold text-sm no-underline active:bg-cta-hover transition-colors"
      >
        Request a Quote
      </a>
    </div>
  </div>
</div>
