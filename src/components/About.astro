---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config/site';

interface Props {
  preview?: boolean;
}

const { preview = false } = Astro.props;
const team = await getCollection('team');
const { business } = siteConfig;
const yearsInBusiness = new Date().getFullYear() - business.foundedYear;
---

<section class="py-16 lg:py-24" id="about">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Images -->
      <div class="grid grid-cols-2 gap-4">
        {team.slice(0, 2).map((member) => (
          <div class="overflow-hidden shadow-md border-2 border-primary clip-corner">
            <img
              src={`/images/team-${member.id.split('-').pop() || member.id}.svg`}
              alt={member.data.name}
              width="400"
              height="400"
              loading="lazy"
              class="w-full h-auto object-cover"
            />
          </div>
        ))}
        {team.length === 1 && (
          <div class="overflow-hidden shadow-md border-2 border-cta clip-corner bg-secondary flex items-center justify-center p-8">
            <img src="/images/logo.svg" alt="Presto Change-Os Handywork logo" width="200" height="200" class="w-full h-auto" />
          </div>
        )}
      </div>

      <!-- Content -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-heading">
          About {business.name}
        </h2>
        <p class="mt-6 text-lg text-muted leading-relaxed">
          Founded in {business.foundedYear}, {business.name} has spent {yearsInBusiness}+ years
          quietly making honey-do lists vanish across the {siteConfig.serviceArea.primary}.
          One wizard, one truck, and a deep commitment to actually showing up — on time,
          with the right tools, at the price that was quoted.
        </p>
        <p class="mt-4 text-muted leading-relaxed">
          The "wizard" thing is mostly a wink — but the no-surprises pricing, the careful
          work, and the one-year workmanship warranty are all very real. Every job comes
          with the same promise: if it isn't right, Preston comes back and makes it right.
        </p>

        {!preview && (
          <div class="mt-8">
            <h3 class="text-xl font-heading font-semibold text-heading mb-4">Our Team</h3>
            <div class="space-y-4">
              {team.map((member) => (
                <div class="p-5 bg-surface border-l-4 border-cta">
                  <p class="font-heading font-extrabold text-heading uppercase tracking-wide">{member.data.name}</p>
                  <p class="text-sm text-cta-hover font-semibold uppercase tracking-widest mt-1">{member.data.role}</p>
                  <p class="mt-3 text-sm text-muted leading-relaxed">{member.data.bio}</p>
                  {member.data.certifications && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {member.data.certifications.map((cert) => (
                        <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 bg-primary text-cta uppercase tracking-wider font-semibold">
                          <span class="star4 w-2.5 h-2.5" aria-hidden="true"></span>
                          {cert}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {preview && (
          <div class="mt-8">
            <a
              href="/about"
              class="inline-flex items-center px-6 py-3 border-2 border-primary text-primary font-semibold rounded-cta hover:bg-primary hover:text-white transition-colors no-underline"
            >
              Learn More About Us
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
