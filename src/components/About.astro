---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config/site';

interface Props {
  preview?: boolean;
}

const { preview = false } = Astro.props;
const team = await getCollection('team');
const { business } = siteConfig;
const yearsInBusiness = new Date().getFullYear() - business.foundedYear;
---

<section class="py-16 sm:py-20 lg:py-28 bg-secondary" id="about">
  <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="text-center mb-10 sm:mb-12">
      <p class="eyebrow"><span>About</span></p>
      <h2 class="mt-5 text-3xl sm:text-4xl lg:text-5xl font-heading font-extrabold text-primary tracking-tight">
        {business.name}
      </h2>
    </div>

    <div class="space-y-5 text-base sm:text-lg text-muted leading-[1.7] max-w-prose mx-auto">
      <p>
        Founded in {business.foundedYear}, {business.name} has spent {yearsInBusiness}+ years
        handling repairs, installs, and small projects across the {siteConfig.serviceArea.primary}.
        One handyman, one truck, and a commitment to actually showing up — on time, with the right
        tools, at the price that was quoted.
      </p>
      <p>
        Up-front communication, careful work, and follow-through are what keep customers calling back.
        Every job comes with the same promise: if it isn't right, Preston comes back and makes it right.
      </p>
    </div>

    {!preview && (
      <div class="mt-14 sm:mt-16">
        <h3 class="text-xs font-semibold uppercase tracking-[0.22em] text-cta-hover mb-5">Behind the Truck</h3>
        <div class="space-y-5">
          {team.map((member) => (
            <div class="bg-white border border-primary/10 rounded-card p-6 sm:p-8 shadow-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-3 border-b border-primary/10 pb-4">
                <p class="font-heading font-extrabold text-primary text-xl sm:text-2xl tracking-tight">
                  {member.data.name}
                </p>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cta-hover">
                  {member.data.role}
                </p>
              </div>
              <p class="mt-4 text-muted leading-relaxed">{member.data.bio}</p>
              {member.data.certifications && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {member.data.certifications.map((cert) => (
                    <span class="inline-block text-[0.6875rem] font-bold uppercase tracking-[0.14em] px-2.5 py-1 bg-primary text-cta rounded">
                      {cert}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    {preview && (
      <div class="mt-10 text-center">
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary font-bold rounded-cta hover:bg-primary hover:text-white transition-colors no-underline"
        >
          More About Us
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
