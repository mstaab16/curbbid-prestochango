---
const steps = [
  {
    number: '1',
    title: 'Send the List',
    description: 'Text or call (512) 300-8483 with your honey-do list — photos welcome. You\'ll usually get a same-day reply.',
  },
  {
    number: '2',
    title: 'Get a Quote',
    description: 'Preston comes out for a free walk-through and gives you a written quote before any work begins.',
  },
  {
    number: '3',
    title: 'Watch It Vanish',
    description: 'On the booked day, the whole list disappears in a single visit. Careful work, clean cleanup.',
  },
];
---

<section class="relative py-16 lg:py-24 bg-primary overflow-hidden">
  <span class="star4 absolute top-10 right-1/4 w-4 h-4 text-cta opacity-50" aria-hidden="true"></span>
  <span class="star4 absolute bottom-12 left-12 w-3 h-3 text-cta opacity-40" aria-hidden="true"></span>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.25em] text-cta mb-3">
        <span class="star4 w-3 h-3" aria-hidden="true"></span>
        The Incantation
      </p>
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-white">How It Works</h2>
      <p class="mt-4 text-lg text-white/70 max-w-2xl mx-auto">
        Three steps from "I should really fix that" to "It's gone."
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      {steps.map((step, i) => (
        <div class="text-center relative">
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-0.5 bg-cta/40" />
          )}
          <div class="mx-auto w-16 h-16 bg-cta text-primary flex items-center justify-center text-2xl font-heading font-extrabold shadow-lg relative z-10 clip-corner">
            {step.number}
          </div>
          <h3 class="mt-6 text-xl font-heading font-extrabold text-white uppercase tracking-wide">{step.title}</h3>
          <p class="mt-3 text-white/70 max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
