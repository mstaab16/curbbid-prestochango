---
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<section class="relative py-16 sm:py-20 lg:py-24 bg-primary text-white overflow-hidden">
  <div class="absolute inset-0 blueprint-grid pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 text-center">
    <p class="eyebrow text-cta"><span>Get Started</span></p>
    <h2 class="mt-5 text-3xl sm:text-4xl lg:text-5xl font-heading font-extrabold tracking-tight">
      Ready to fix that list?
    </h2>
    <p class="mt-4 sm:mt-5 text-base sm:text-lg text-white/75 max-w-xl mx-auto leading-relaxed">
      Free quote, fast reply, no pressure. Same-week booking is usually available.
    </p>
    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 max-w-xl mx-auto">
      <a
        href="/contact"
        class="flex-1 inline-flex items-center justify-center px-6 py-4 sm:py-5 bg-cta text-primary font-bold text-base sm:text-lg rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline shadow-[0_2px_0_0_var(--color-cta-hover)]"
      >
        Request a Quote
      </a>
      <a
        href={telHref}
        class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 sm:py-5 border-2 border-white text-white font-bold text-base sm:text-lg rounded-cta hover:bg-white hover:text-primary transition-colors no-underline"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="tabular-nums">{business.phone}</span>
      </a>
    </div>
  </div>
</section>
