---
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
---

<section class="relative py-16 lg:py-20 bg-primary overflow-hidden border-y-2 border-cta/40">
  <span class="star4 absolute top-8 left-8 w-5 h-5 text-cta opacity-60" aria-hidden="true"></span>
  <span class="star4 absolute bottom-8 right-12 w-6 h-6 text-cta opacity-50" aria-hidden="true"></span>
  <span class="star4 absolute top-1/2 right-1/4 w-3 h-3 text-cta opacity-40" aria-hidden="true"></span>
  <span class="star4 absolute bottom-12 left-1/4 w-2 h-2 text-accent opacity-50" aria-hidden="true"></span>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.25em] text-cta mb-4">
      <span class="star4 w-3 h-3" aria-hidden="true"></span>
      No Obligation, No Hocus Pocus
    </p>
    <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-white">
      Ready to Make That List Vanish?
    </h2>
    <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
      Send Preston your honey-do list — text or call — and you'll usually have a same-day quote and the next available slot.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta text-primary font-bold text-lg uppercase tracking-wider rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline shadow-lg"
      >
        <span class="star4 w-4 h-4" aria-hidden="true"></span>
        Get a Quote
      </a>
      <a
        href={`tel:${business.phone.replace(/[^+\d]/g, '')}`}
        class="inline-flex items-center px-8 py-4 border-2 border-white text-white font-bold text-lg rounded-cta hover:bg-white hover:text-primary transition-colors no-underline"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {business.phone}
      </a>
    </div>
  </div>
</section>
