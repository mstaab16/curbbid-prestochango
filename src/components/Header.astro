---
import { siteConfig, navLinks } from '@/config/site';
import MobileNav from './MobileNav.astro';

const { business } = siteConfig;
---

<header class="sticky top-0 z-50 bg-white border-b border-primary/15 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo + Name -->
      <a href="/" class="flex items-center gap-3 no-underline shrink-0">
        <img src="/images/logo.svg" alt="" width="40" height="40" class="w-9 h-9 lg:w-10 lg:h-10 text-primary" />
        <span class="flex items-baseline gap-1.5 text-base lg:text-xl font-heading font-extrabold text-primary uppercase tracking-wider">
          Presto<span class="text-cta">Change-Os</span>
          <span class="star4 text-cta w-3 h-3 self-center" aria-hidden="true"></span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-heading hover:text-primary transition-colors no-underline"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${business.phone.replace(/[^+\d]/g, '')}`}
          class="text-sm font-semibold text-primary no-underline"
        >
          {business.phone}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-cta text-primary text-sm font-bold uppercase tracking-wider rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline"
        >
          <span class="star4 w-3 h-3" aria-hidden="true"></span>
          Cast a Quote
        </a>
      </div>

      <!-- Mobile: Phone + Hamburger -->
      <div class="flex items-center gap-3 lg:hidden">
        <a
          href={`tel:${business.phone.replace(/[^+\d]/g, '')}`}
          class="text-primary no-underline"
          aria-label="Call us"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <button
          id="mobile-nav-toggle"
          type="button"
          class="p-2 text-heading hover:text-primary transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<MobileNav />
