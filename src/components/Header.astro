---
import { siteConfig, navLinks } from '@/config/site';
import MobileNav from './MobileNav.astro';

const { business } = siteConfig;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<header class="sticky top-0 z-40 bg-white border-b border-primary/15">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20 gap-3">
      <a href="/" class="flex items-center gap-2.5 sm:gap-3 no-underline shrink-0 min-w-0">
        <img src="/images/logo.png" alt="" width="40" height="40" class="w-9 h-9 lg:w-10 lg:h-10 shrink-0" />
        <span class="font-heading font-extrabold text-primary leading-none truncate">
          <span class="block sm:hidden text-base">Presto Change-O's</span>
          <span class="hidden sm:block lg:hidden text-base">Presto Change-O's Handywork</span>
          <span class="hidden lg:block text-lg">Presto Change-O's Handywork</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-heading hover:text-cta-hover transition-colors no-underline"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center gap-4 shrink-0">
        <a href={telHref} class="text-sm font-semibold text-primary no-underline tabular-nums">
          {business.phone}
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 bg-cta text-primary text-sm font-bold rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline"
        >
          Request a Quote
        </a>
      </div>

      <div class="flex items-center gap-2 lg:hidden shrink-0">
        <a
          href={telHref}
          class="inline-flex items-center justify-center w-10 h-10 text-primary border border-primary/20 rounded no-underline hover:bg-primary hover:text-white transition-colors"
          aria-label="Call us"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <button
          id="mobile-nav-toggle"
          type="button"
          class="inline-flex items-center justify-center w-10 h-10 text-heading hover:text-primary transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<MobileNav />
