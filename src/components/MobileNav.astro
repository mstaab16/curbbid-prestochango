---
import { siteConfig, navLinks } from '@/config/site';

const { business } = siteConfig;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<div
  id="mobile-nav-overlay"
  class="fixed inset-0 z-50 bg-primary/60 backdrop-blur-sm hidden"
  aria-hidden="true"
></div>

<nav
  id="mobile-nav"
  class="fixed top-0 right-0 z-50 h-full w-[88vw] max-w-sm bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-out flex flex-col"
  aria-label="Mobile navigation"
>
  <div class="flex items-center justify-between p-5 border-b border-primary/15">
    <span class="flex items-center gap-2.5 min-w-0">
      <img src="/images/logo.png" alt="" width="32" height="32" class="w-8 h-8 shrink-0" />
      <span class="font-heading font-extrabold text-primary text-sm leading-tight truncate">
        {business.name}
      </span>
    </span>
    <button
      id="mobile-nav-close"
      type="button"
      class="p-2 -mr-2 text-heading hover:text-primary transition-colors shrink-0"
      aria-label="Close menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex flex-col p-3 gap-0.5 flex-1">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="py-3 px-4 text-base text-heading font-semibold rounded-card hover:bg-secondary hover:text-cta-hover transition-colors no-underline"
      >
        {link.label}
      </a>
    ))}
  </div>

  <div class="p-5 border-t border-primary/10 bg-secondary">
    <a
      href={telHref}
      class="flex items-center gap-2.5 py-2 text-primary font-bold no-underline tabular-nums"
    >
      <svg class="w-5 h-5 text-cta-hover" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      {business.phone}
    </a>
    <a
      href="/contact"
      class="mt-3 flex items-center justify-center px-5 py-3.5 bg-cta text-primary font-bold rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline w-full"
    >
      Request a Quote
    </a>
    <div class="mt-4 text-xs text-muted leading-relaxed">
      {business.hours.map((h) => (
        <p class="py-0.5">{h.days}: {h.hours}</p>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const close = document.getElementById('mobile-nav-close');
  const nav = document.getElementById('mobile-nav');
  const overlay = document.getElementById('mobile-nav-overlay');

  function openNav() {
    nav?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeNav() {
    nav?.classList.add('translate-x-full');
    overlay?.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openNav);
  close?.addEventListener('click', closeNav);
  overlay?.addEventListener('click', closeNav);
  nav?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav));
</script>
