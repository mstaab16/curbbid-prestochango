---
import { getCollection } from 'astro:content';

interface Props {
  category?: string;
  limit?: number;
}

const { category, limit } = Astro.props;
let items = await getCollection('faq');

if (category) {
  items = items.filter((item) => item.data.category === category);
}
if (limit) {
  items = items.slice(0, limit);
}

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.data.answer,
    },
  })),
};
---

<section class="py-16 sm:py-20 lg:py-24 bg-secondary" id="faq">
  <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="text-center mb-10 sm:mb-12">
      <p class="eyebrow"><span>FAQ</span></p>
      <h2 class="mt-5 text-3xl sm:text-4xl lg:text-5xl font-heading font-extrabold text-primary tracking-tight">
        Common Questions
      </h2>
      <p class="mt-4 text-base sm:text-lg text-muted">
        Don't see yours? Text Preston at <a href="tel:5123008483" class="text-primary font-semibold underline-offset-2 hover:underline">(512) 300-8483</a>.
      </p>
    </div>

    <div class="border-t border-primary/15">
      {items.map((item, i) => (
        <details class="group border-b border-primary/15">
          <summary class="flex items-center justify-between gap-6 py-5 sm:py-6 cursor-pointer list-none">
            <span class="flex items-baseline gap-3 sm:gap-4">
              <span class="numeral text-cta-hover/80 text-sm sm:text-base shrink-0 mt-0.5 tabular-nums">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-heading font-bold text-primary text-base sm:text-lg leading-snug">
                {item.data.question}
              </span>
            </span>
            <span class="shrink-0 w-7 h-7 inline-flex items-center justify-center border border-primary/30 rounded-full text-muted group-open:bg-primary group-open:text-white group-open:border-primary transition-colors">
              <svg class="w-3.5 h-3.5 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </summary>
          <div class="pb-5 sm:pb-6 pl-9 sm:pl-12 pr-2 text-muted leading-relaxed">
            {item.data.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
