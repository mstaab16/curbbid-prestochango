---
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<form
  name="contact"
  method="POST"
  netlify
  netlify-honeypot="bot-field"
  action="/contact/?success=1"
  class="space-y-5"
  id="contact-form"
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden">
    <label>Don't fill this out if you're human: <input name="bot-field" /></label>
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-heading mb-1.5">
        Full Name <span class="text-cta">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full px-4 py-3 border border-gray-300 rounded-card text-heading bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
        placeholder="Jane Smith"
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-medium text-heading mb-1.5">
        Phone Number <span class="text-cta">*</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        autocomplete="tel"
        class="w-full px-4 py-3 border border-gray-300 rounded-card text-heading bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
        placeholder="(512) 555-0100"
      />
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-heading mb-1.5">
      Email Address
    </label>
    <input
      type="email"
      id="email"
      name="email"
      autocomplete="email"
      class="w-full px-4 py-3 border border-gray-300 rounded-card text-heading bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
      placeholder="you@example.com"
    />
  </div>

  <div>
    <label for="service" class="block text-sm font-medium text-heading mb-1.5">
      Service Needed
    </label>
    <select
      id="service"
      name="service"
      class="w-full px-4 py-3 border border-gray-300 rounded-card text-heading bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors"
    >
      <option value="">Select a service...</option>
      {services.map((s) => (
        <option value={s.data.title}>{s.data.title}</option>
      ))}
      <option value="Other">Other</option>
    </select>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-heading mb-1.5">
      Tell Us About Your Project
    </label>
    <textarea
      id="message"
      name="message"
      rows="4"
      class="w-full px-4 py-3 border border-gray-300 rounded-card text-heading bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors resize-y"
      placeholder="Tell Preston what you need fixed or installed. The more detail, the better."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-cta text-primary font-bold text-lg rounded-cta hover:bg-cta-hover hover:text-white transition-colors shadow-md cursor-pointer"
  >
    Send Message
  </button>
</form>

<script>
  // After Netlify accepts the POST, the page reloads with ?success=1.
  // Swap the form for a thank-you panel so the user sees confirmation.
  if (new URLSearchParams(window.location.search).get('success') === '1') {
    const form = document.getElementById('contact-form');
    if (form) {
      form.outerHTML =
        '<div class="text-center py-12 px-6 bg-surface border-l-4 border-cta rounded-card"><svg class="w-16 h-16 text-cta-hover mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><h3 class="text-2xl font-heading font-bold text-heading">Message Sent!</h3><p class="mt-2 text-muted">Preston will get back to you shortly.</p></div>';
    }
  }
</script>
