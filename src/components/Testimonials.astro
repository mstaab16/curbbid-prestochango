---
import { getCollection } from 'astro:content';

const testimonials = await getCollection('testimonials');
---

<section class="py-16 lg:py-24 bg-surface relative overflow-hidden">
  <span class="star4 absolute top-12 left-12 w-4 h-4 text-cta opacity-30" aria-hidden="true"></span>
  <span class="star4 absolute bottom-12 right-16 w-3 h-3 text-cta opacity-30" aria-hidden="true"></span>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.25em] text-cta-hover mb-3">
        <span class="star4 w-3 h-3" aria-hidden="true"></span>
        Word From the Faithful
      </p>
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-heading">What Neighbors Are Saying</h2>
      <p class="mt-4 text-lg text-muted">
        5.0 stars across every review. No exceptions, no asterisks.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <div class="relative bg-white p-6 border border-primary/10 clip-corner">
          <span class="star4 absolute top-3 right-3 w-3 h-3 text-cta" aria-hidden="true"></span>
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.data.rating }).map(() => (
              <span class="star4 w-5 h-5 text-cta-hover" aria-hidden="true"></span>
            ))}
          </div>
          <blockquote class="text-heading leading-relaxed">
            "{t.data.text}"
          </blockquote>
          <div class="mt-5 flex items-center justify-between">
            <div>
              <p class="font-heading font-extrabold text-heading uppercase tracking-wide">{t.data.name}</p>
              {t.data.location && (
                <p class="text-xs text-muted uppercase tracking-widest mt-0.5">{t.data.location}</p>
              )}
            </div>
            <span class="text-[10px] px-2.5 py-1 bg-primary text-cta uppercase tracking-widest font-bold">
              {t.data.service}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
