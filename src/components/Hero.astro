---
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
const yearsInBusiness = new Date().getFullYear() - business.foundedYear;
---

<section class="relative bg-secondary overflow-hidden border-b border-primary/15">
  <!-- Decorative four-pointed stars -->
  <span class="star4 absolute top-12 left-8 w-4 h-4 text-cta opacity-70" aria-hidden="true"></span>
  <span class="star4 absolute top-32 right-1/3 w-2 h-2 text-primary opacity-50" aria-hidden="true"></span>
  <span class="star4 absolute bottom-24 left-1/3 w-3 h-3 text-cta opacity-50" aria-hidden="true"></span>
  <span class="star4 absolute bottom-10 right-10 w-5 h-5 text-primary opacity-30" aria-hidden="true"></span>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div>
        <p class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.2em] text-cta-hover bg-accent/30 border border-cta/40 px-3 py-1.5 mb-6">
          <span class="star4 w-3 h-3" aria-hidden="true"></span>
          North Austin's Handyman Wizard
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-heading leading-tight">
          {business.tagline}
        </h1>
        <p class="mt-6 text-lg text-muted max-w-xl">
          {business.description}
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-cta text-primary font-bold text-lg uppercase tracking-wider rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline shadow-lg"
          >
            <span class="star4 w-4 h-4" aria-hidden="true"></span>
            Cast a Quote
          </a>
          <a
            href={`tel:${business.phone.replace(/[^+\d]/g, '')}`}
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary text-primary font-bold text-lg rounded-cta hover:bg-primary hover:text-white transition-colors no-underline"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {business.phone}
          </a>
        </div>
        <!-- Trust Stats -->
        <div class="mt-10 flex flex-wrap gap-8">
          <div>
            <p class="text-3xl font-heading font-extrabold text-primary">{yearsInBusiness}+</p>
            <p class="text-xs uppercase tracking-widest text-muted mt-1">Years Casting</p>
          </div>
          <div>
            <p class="text-3xl font-heading font-extrabold text-primary">300+</p>
            <p class="text-xs uppercase tracking-widest text-muted mt-1">Spells Cast</p>
          </div>
          <div>
            <p class="text-3xl font-heading font-extrabold text-primary">5.0</p>
            <p class="text-xs uppercase tracking-widest text-muted mt-1">Star Rating</p>
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="relative">
        <div class="absolute -top-3 -left-3 w-full h-full border-2 border-cta/40" aria-hidden="true"></div>
        <div class="relative overflow-hidden shadow-2xl border-2 border-primary clip-corner">
          <img
            src="/images/hero-placeholder.svg"
            alt={`${business.name} - North Austin's wizardly handyman`}
            width="800"
            height="600"
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
