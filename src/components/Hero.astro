---
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
const yearsInBusiness = new Date().getFullYear() - business.foundedYear;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<section class="relative bg-secondary overflow-hidden">
  <div class="absolute inset-0 blueprint-grid-light pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-x-0 top-0 h-1 bg-primary" aria-hidden="true"></div>

  <div class="relative max-w-5xl mx-auto px-5 sm:px-6 lg:px-8 pt-12 sm:pt-16 lg:pt-24 pb-14 sm:pb-20 lg:pb-24 text-center">
    <p class="eyebrow">
      <span>Serving {siteConfig.serviceArea.primary}</span>
    </p>

    <h1 class="mt-6 font-heading font-black text-primary tracking-tight text-[2.5rem] leading-[1.02] sm:text-6xl lg:text-7xl">
      Handyman Services<br class="hidden sm:inline" />
      <span class="text-cta-hover"> in North Austin</span>
    </h1>

    <p class="mt-5 sm:mt-7 text-base sm:text-lg lg:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
      Repairs, installs, carpentry, drywall, mounting, fixtures, and small projects — done right the first time, at the price quoted.
    </p>

    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 max-w-xl mx-auto">
      <a
        href="/contact"
        class="flex-1 inline-flex items-center justify-center px-6 py-4 sm:py-5 bg-cta text-primary font-bold text-base sm:text-lg rounded-cta hover:bg-cta-hover hover:text-white transition-colors no-underline shadow-[0_2px_0_0_var(--color-primary)]"
      >
        Request a Quote
      </a>
      <a
        href={telHref}
        class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 sm:py-5 bg-primary text-white font-bold text-base sm:text-lg rounded-cta hover:bg-heading transition-colors no-underline shadow-[0_2px_0_0_var(--color-cta-hover)]"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="tabular-nums">Call {business.phone}</span>
      </a>
    </div>

    <div class="mt-12 sm:mt-16 grid grid-cols-3 max-w-2xl mx-auto border-y border-primary/15 divide-x divide-primary/15">
      <div class="py-5 sm:py-6 px-2">
        <p class="numeral text-primary text-3xl sm:text-4xl">
          {yearsInBusiness}<span class="text-cta-hover">+</span>
        </p>
        <p class="mt-2 text-[0.6875rem] sm:text-xs uppercase tracking-[0.18em] text-muted font-semibold">
          Years Working
        </p>
      </div>
      <div class="py-5 sm:py-6 px-2">
        <p class="numeral text-primary text-3xl sm:text-4xl">
          300<span class="text-cta-hover">+</span>
        </p>
        <p class="mt-2 text-[0.6875rem] sm:text-xs uppercase tracking-[0.18em] text-muted font-semibold">
          Jobs Completed
        </p>
      </div>
      <div class="py-5 sm:py-6 px-2">
        <p class="numeral text-primary text-3xl sm:text-4xl tabular-nums">
          5.0<span class="text-cta-hover">★</span>
        </p>
        <p class="mt-2 text-[0.6875rem] sm:text-xs uppercase tracking-[0.18em] text-muted font-semibold">
          Star Rating
        </p>
      </div>
    </div>
  </div>
</section>
