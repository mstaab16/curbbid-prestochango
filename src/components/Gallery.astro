---
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
let items = await getCollection('gallery');
if (limit) {
  items = items.slice(0, limit);
}
---

<section class="py-16 lg:py-24" id="gallery">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-heading">Our Work</h2>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
        Recent spells cast across Round Rock, Hutto, Georgetown, and the rest of the North Austin metro.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {items.map((item) => (
        <div class="bg-surface border border-primary/15 overflow-hidden clip-corner">
          <img
            src="/images/gallery-placeholder.svg"
            alt={item.data.title}
            width="600"
            height="400"
            loading="lazy"
            class="w-full h-48 sm:h-64 object-cover"
          />
          <div class="p-5">
            <span class="inline-flex items-center gap-1.5 text-[10px] px-2.5 py-1 bg-primary text-cta uppercase tracking-widest font-bold">
              <span class="star4 w-2.5 h-2.5" aria-hidden="true"></span>
              {item.data.service}
            </span>
            <h3 class="mt-3 text-lg font-heading font-extrabold text-heading uppercase tracking-wide">{item.data.title}</h3>
            <p class="mt-2 text-sm text-muted">{item.data.description}</p>
          </div>
        </div>
      ))}
    </div>

    {limit && (
      <div class="mt-10 text-center">
        <a
          href="/gallery"
          class="inline-flex items-center px-6 py-3 border-2 border-primary text-primary font-semibold rounded-cta hover:bg-primary hover:text-white transition-colors no-underline"
        >
          View Full Gallery
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
