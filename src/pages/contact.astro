---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';
import { siteConfig } from '@/config/site';

const { business } = siteConfig;
const telHref = `tel:${business.phone.replace(/[^+\d]/g, '')}`;
---

<BaseLayout title="Contact" description="Request a free handyman quote in North Austin. Call (512) 300-8483, email, or fill out the form. Same-day reply, free quotes.">
  <section class="py-14 sm:py-20 lg:py-24 bg-secondary border-b border-primary/15">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 text-center">
      <p class="eyebrow"><span>Contact</span></p>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-primary tracking-tight">
        Request a Free Quote
      </h1>
      <p class="mt-5 text-base sm:text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        Call, text, or fill out the form. Most replies happen the same day, with a quote and the next available slot.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">
        <div class="lg:col-span-2">
          <ContactForm />
        </div>

        <aside class="space-y-4">
          <div class="bg-primary text-white p-6 rounded-card">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-cta mb-3">Call or Text</p>
            <a
              href={telHref}
              class="block text-2xl sm:text-3xl font-heading font-extrabold text-white no-underline hover:text-cta transition-colors tabular-nums"
            >
              {business.phone}
            </a>
            <p class="mt-3 text-sm text-white/70">Direct line to Preston — no call center.</p>
          </div>

          <div class="border border-primary/15 rounded-card p-6">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-cta-hover mb-2">Email</p>
            <a
              href={`mailto:${business.email}`}
              class="text-primary font-semibold no-underline break-all hover:text-cta-hover"
            >
              {business.email}
            </a>
          </div>

          <div class="border border-primary/15 rounded-card p-6">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-cta-hover mb-2">Service Area</p>
            <p class="text-muted text-sm leading-relaxed">
              Based in {business.address.city}, {business.address.state}. Serving Round Rock, Hutto, Georgetown, Pflugerville, Cedar Park, Leander, and the rest of the North Austin metro.
            </p>
          </div>

          <div class="border border-primary/15 rounded-card p-6">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-cta-hover mb-3">Hours</p>
            <dl class="space-y-1.5 text-sm">
              {business.hours.map((h) => (
                <div class="flex justify-between gap-3">
                  <dt class="text-muted">{h.days}</dt>
                  <dd class="font-semibold text-primary tabular-nums text-right">{h.hours}</dd>
                </div>
              ))}
            </dl>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
