---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Gallery from '@/components/Gallery.astro';
import CTABanner from '@/components/CTABanner.astro';
import { siteConfig } from '@/config/site';

if (!siteConfig.features.enableGallery) {
  return Astro.redirect('/', 302);
}
---

<BaseLayout title="Gallery" description="Recent handyman projects across Round Rock, Hutto, Georgetown, and the rest of North Austin.">
  <section class="py-14 sm:py-20 lg:py-24 bg-secondary border-b border-primary/15">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 text-center">
      <p class="eyebrow"><span>Recent Work</span></p>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-primary tracking-tight">
        Project Gallery
      </h1>
      <p class="mt-5 text-base sm:text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        A few recent jobs from across the North Austin metro. Real photos coming soon — these are placeholders.
      </p>
    </div>
  </section>
  <Gallery />
  <CTABanner />
</BaseLayout>
