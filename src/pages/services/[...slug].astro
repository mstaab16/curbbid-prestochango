---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/CTABanner.astro';
import FAQ from '@/components/FAQ.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${Astro.site}services` },
    { '@type': 'ListItem', position: 3, name: service.data.title },
  ],
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.data.title,
  description: service.data.excerpt,
  provider: {
    '@type': 'HomeAndConstructionBusiness',
    name: siteConfig.business.name,
    telephone: siteConfig.business.phone,
  },
};
---

<BaseLayout
  title={service.data.title}
  description={service.data.excerpt}
  jsonLd={[breadcrumbJsonLd, serviceJsonLd]}
>
  <article class="py-14 sm:py-20 lg:py-24">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8">
      <nav class="mb-8 text-xs sm:text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 flex-wrap">
          <li><a href="/" class="text-muted hover:text-cta-hover no-underline">Home</a></li>
          <li class="text-primary/30">/</li>
          <li><a href="/services" class="text-muted hover:text-cta-hover no-underline">Services</a></li>
          <li class="text-primary/30">/</li>
          <li class="text-primary font-medium">{service.data.title}</li>
        </ol>
      </nav>

      <p class="eyebrow eyebrow--start"><span>Service</span></p>
      <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-primary tracking-tight leading-[1.05]">
        {service.data.title}
      </h1>
      <p class="mt-5 text-base sm:text-lg text-muted leading-relaxed">{service.data.excerpt}</p>

      {service.data.symptoms && (
        <div class="mt-10 sm:mt-12 bg-secondary rounded-card p-6 sm:p-8">
          <h2 class="text-xs font-bold uppercase tracking-[0.22em] text-cta-hover mb-4">
            Signs You May Need This
          </h2>
          <ul class="space-y-2.5">
            {service.data.symptoms.map((symptom) => (
              <li class="flex items-start gap-3 text-primary">
                <svg class="w-4 h-4 text-cta-hover shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="leading-relaxed">{symptom}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-10 sm:mt-12 prose prose-lg prose-headings:font-heading prose-headings:text-primary prose-headings:tracking-tight prose-a:text-primary prose-a:font-semibold max-w-none">
        <Content />
      </div>
    </div>
  </article>

  <FAQ limit={5} />
  <CTABanner />
</BaseLayout>
