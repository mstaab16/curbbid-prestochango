---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTABanner from '@/components/CTABanner.astro';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const iconModules = import.meta.glob('/src/assets/icons/*.svg', {
  query: '?raw',
  import: 'default',
});

const servicesWithIcons = await Promise.all(
  services.map(async (service) => {
    const iconPath = `/src/assets/icons/${service.data.icon}.svg`;
    const iconRaw = iconModules[iconPath]
      ? ((await iconModules[iconPath]()) as string)
      : '';
    return { service, iconRaw };
  })
);
---

<BaseLayout title="Services" description="Handyman services for North Austin: small repairs, carpentry, drywall, mounting, painting, doors, fixtures, and exterior repairs. Honest pricing, careful work.">
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="inline-flex items-center gap-2 text-xs font-heading font-bold uppercase tracking-[0.25em] text-cta-hover mb-3">
          <span class="star4 w-3 h-3" aria-hidden="true"></span>
          The Spell Book
        </p>
        <h1 class="text-4xl sm:text-5xl font-heading font-extrabold text-heading">All Services</h1>
        <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
          Eight common spells, plus all the small stuff that doesn't fit a category. If it's bugging you, ask.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {servicesWithIcons.map(({ service, iconRaw }) => (
          <a
            href={`/services/${service.id}`}
            class="group relative flex gap-5 p-6 bg-white border border-primary/15 hover:border-cta hover:shadow-lg transition-all duration-200 no-underline clip-corner"
          >
            <span class="star4 absolute top-3 right-3 w-3 h-3 text-cta opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true"></span>
            <div class="w-14 h-14 text-cta-hover shrink-0" set:html={iconRaw} />
            <div>
              <h2 class="text-xl font-heading font-extrabold text-heading uppercase tracking-wide group-hover:text-cta-hover transition-colors">
                {service.data.title}
              </h2>
              <p class="mt-2 text-muted">{service.data.excerpt}</p>
              <span class="mt-3 inline-flex items-center text-xs uppercase tracking-widest font-bold text-cta-hover">
                Read the Spell
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <CTABanner />
</BaseLayout>
