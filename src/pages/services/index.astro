---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTABanner from '@/components/CTABanner.astro';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const iconModules = import.meta.glob('/src/assets/icons/*.svg', {
  query: '?raw',
  import: 'default',
});

const servicesWithIcons = await Promise.all(
  services.map(async (service) => {
    const iconPath = `/src/assets/icons/${service.data.icon}.svg`;
    const iconRaw = iconModules[iconPath]
      ? ((await iconModules[iconPath]()) as string)
      : '';
    return { service, iconRaw };
  })
);
---

<BaseLayout title="Services" description="Handyman services for North Austin: small repairs, carpentry, drywall, mounting, painting, doors, fixtures, and exterior repairs. Honest pricing, careful work.">
  <section class="py-14 sm:py-20 lg:py-24 bg-secondary border-b border-primary/15">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 text-center">
      <p class="eyebrow"><span>What We Do</span></p>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-primary tracking-tight">
        All Services
      </h1>
      <p class="mt-5 text-base sm:text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        Eight common categories, plus the small stuff in between. If it's bugging you, ask.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-primary/10 border border-primary/10 rounded-card overflow-hidden">
        {servicesWithIcons.map(({ service, iconRaw }, i) => (
          <a
            href={`/services/${service.id}`}
            class="group relative flex gap-5 p-6 sm:p-8 bg-white hover:bg-secondary transition-colors duration-200 no-underline"
          >
            <span class="corner-mark">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="w-14 h-14 text-cta-hover shrink-0" set:html={iconRaw} />
            <div class="min-w-0">
              <h2 class="text-xl sm:text-2xl font-heading font-extrabold text-primary group-hover:text-cta-hover transition-colors tracking-tight leading-tight">
                {service.data.title}
              </h2>
              <p class="mt-2 text-muted leading-relaxed">{service.data.excerpt}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-[0.18em] text-cta-hover">
                Learn More
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <CTABanner />
</BaseLayout>
